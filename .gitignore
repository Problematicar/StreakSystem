# ==========================================
# Never commit private API keys, certs, or environment variables
.env
.env.local
.env.*.local
*.pfx
*.p12
*.pem
*.key

# ==========================================
# Operating System Artifacts
# ==========================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# IDEs and Editors
# ==========================================
.vscode/
